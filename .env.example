# ============================================================
# Ghost Coach — Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit the .env file with real secrets.
# ============================================================

# ---- Gemini Vision API (free via aistudio.google.com) ----
GEMINI_API_KEY=your-gemini-api-key-here

# ---- JWT ----
# Must be at least 64 characters for HS256 security
JWT_SECRET=replace-this-with-a-random-64-char-string-never-commit-to-git!!
JWT_EXPIRATION_MS=86400000

# ---- Database (dev uses H2 file DB — no changes needed) ----
# For production PostgreSQL:
# DATABASE_URL=jdbc:postgresql://localhost:5432/ghostcoach
# DATABASE_USER=ghostcoach
# DATABASE_PASSWORD=changeme

# ---- File uploads ----
UPLOAD_DIR=./uploads

# ---- Spring profile ----
SPRING_PROFILE=dev

# ---- CORS (frontend origins) ----
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Frontend ----
REACT_APP_API_URL=http://localhost:8080
